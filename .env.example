# kamaho-shokusu.jp API 認証情報
KAMAHO_BASE_URL=https://kamaho-shokusu.jp
KAMAHO_LOGIN_ACCOUNT=your-account
KAMAHO_LOGIN_PASSWORD=your-password

# DB
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=meal_order_db
MYSQL_USER=cake_user
MYSQL_PASSWORD=secret

# Host port settings for Docker Compose
WEB_PORT=80
FRONTEND_PORT=3000
DB_PORT=3306

# Local LLM (Ollama)
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:1.5b-instruct-q4_K_S

# AI公開設定
AI_PUBLIC_ENABLED=false
NEXT_PUBLIC_AI_PUBLIC_ENABLED=false

# LLM Provider
AI_PROVIDER=openrouter
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=qwen/qwen3-4b:free
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=meal-order-system
